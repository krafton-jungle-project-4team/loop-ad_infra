export function synthPerfPhase4ClickHouseEcs(
    context: Record<string, unknown> = {},
): LoopAdPerfPhase4ClickHouseEcsStack {
    const app = new cdk.App({
        context: {
            '@aws-cdk/aws-autoscaling:generateLaunchTemplateInsteadOfLaunchConfig': true,
            ...testPhase4EcsContext,
            ...context,
        },
    });
    const imageStack = new LoopAdPerfPhase4ClickHouseEcsImageStack(
        app,
        'LoopAdPerfPhase4ClickHouseEcsImageStack',
        { env: testEnv },
    );
    const stack = new LoopAdPerfPhase4ClickHouseEcsStack(
        app,
        'LoopAdPerfPhase4ClickHouseEcsStack',
        {
            env: testEnv,
            consumerRepository: imageStack.repository,
        },
    );
    stack.addDependency(imageStack);
    return stack;
}

