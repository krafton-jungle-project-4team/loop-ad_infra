#!/usr/bin/env node

import { execFileSync } from 'node:child_process';
import { createHash } from 'node:crypto';
import { mkdirSync, readFileSync, unlinkSync, writeFileSync } from 'node:fs';
import { dirname, join } from 'node:path';
import { fileURLToPath } from 'node:url';
import { gzipSync } from 'node:zlib';
import { runBoundedAwsObservation } from './aws-observation-retry.mjs';
import { isConnectionPathDestinationUrl } from './connection-path-destination.mjs';
import { PATH_EVIDENCE_EXPERIMENT_MODES, resolveOhaConnections } from './oha-load-contract.mjs';

const REGION = 'ap-northeast-2';
const TRANSFER_PROBE_BYTES = 20 * 1_024;
const AWS_CLI_SINGLE_ATTEMPT_ENV = Object.freeze({
    AWS_MAX_ATTEMPTS: '1',
    AWS_RETRY_MODE: 'standard',
});
const AWS_CLI_SHORT_TIMEOUT_ARGS = Object.freeze([
    '--cli-connect-timeout', '5',
    '--cli-read-timeout', '10',
]);
const ACTIVE_SSM_STATUSES = new Set(['Pending', 'InProgress', 'Delayed', 'Cancelling']);
const TERMINAL_SSM_STATUSES = new Set(['Success', 'Cancelled', 'TimedOut', 'Failed']);
const S3_ARTIFACT_DOWNLOAD_DEADLINE_MS = 120_000;
const scriptDir = dirname(fileURLToPath(import.meta.url));
const poolPath = optionValue('--payload-pool') ?? join(scriptDir, 'payloads', 'sdk-compatible-event-bodies.ndjson');
const manifestPath = optionValue('--payload-manifest') ?? join(scriptDir, 'payloads', 'sdk-compatible-event-bodies.manifest.json');
const instanceId = requiredOption('--instance-id');
const targetBaseUrl = requiredOption('--target-base-url');
const targetConnectBaseUrlOption = optionValue('--target-connect-base-url');
const targetPath = optionValue('--target-path') ?? '/events';
const stageLabel = optionValue('--stage-label') ?? 'unspecified';
const repetition = optionValue('--repetition') ?? '1';
const instrumentation = optionValue('--instrumentation') ?? 'on';
const targetIp = optionValue('--target-ip');
const directTargetIp = optionValue('--direct-target-ip');
const runId = requiredOption('--run-id');
const rps = requiredInteger('--rps');
const durationSeconds = requiredInteger('--duration-seconds');
const experimentMode = optionValue('--experiment-mode') ?? 'legacy';
const explicitConnections = optionalInteger('--connections');
const connections = resolveOhaConnections({ rps, explicitConnections, experimentMode });
const processesPerNode = integerOption('--processes-per-node', 1);
const processStartSpacingSeconds = integerOption('--process-start-spacing-seconds', 0);
const processStartOffsetSeconds = integerOption('--process-start-offset-seconds', 0);
const startEpoch = integerOption('--start-epoch', 0);
const nodeId = optionValue('--node-id') ?? 'node-01';
const evidenceBucket = optionValue('--evidence-bucket');
const evidencePrefix = optionValue('--evidence-prefix');
const outputDir = requiredOption('--output-dir');
const pathEvidenceMode = PATH_EVIDENCE_EXPERIMENT_MODES.includes(experimentMode);
const connectionPathMode = experimentMode === 'connection-path-crossover';
const tlsServerName = optionValue('--tls-server-name');
const caCertificatePath = optionValue('--ca-certificate');

if (!/^i-[0-9a-f]+$/.test(instanceId)) throw new Error('invalid EC2 instance ID');
if (connectionPathMode) {
    if (!/^https:\/\/[a-z0-9.-]+$/.test(targetBaseUrl) || targetBaseUrl !== `https://${tlsServerName}`) throw new Error('invalid canonical connection-path TLS URL');
    if (!isConnectionPathDestinationUrl(targetConnectBaseUrlOption)) throw new Error('invalid run-scoped connection-path destination URL');
    if (!caCertificatePath) throw new Error('connection-path mode requires --ca-certificate');
} else if (!/^http:\/\/internal-(?:perf-phase1-loop-ad-alb|perf-phase1-generator-control)-[a-z0-9-]+\.ap-northeast-2\.elb\.amazonaws\.com$/.test(targetBaseUrl)) throw new Error('invalid internal Phase 1 ALB URL');
if (!/^run_[0-9]{8}_[0-9]{6}_[a-z0-9][a-z0-9_-]{0,31}$/.test(runId)) throw new Error('invalid run ID');
if (!isAllowedTargetPath(targetPath)) throw new Error('invalid target path');
if (!/^[a-z0-9][a-z0-9_-]{0,31}$/.test(stageLabel) || !/^[0-9]{1,3}$/.test(repetition)) throw new Error('invalid stage metadata');
if (!['on', 'off'].includes(instrumentation)) throw new Error('invalid instrumentation mode');
if (!/^node-[0-9]{2}$/.test(nodeId)) throw new Error('invalid node ID');
if (targetIp && directTargetIp) throw new Error('ALB frontend and direct target pinning are mutually exclusive');
if (connectionPathMode && (targetIp || directTargetIp)) throw new Error('connection-path mode uses --target-connect-base-url, not IP pinning');
if ((targetIp || directTargetIp) && (!isPrivateIpv4(targetIp ?? directTargetIp) || !pathEvidenceMode)) {
    throw new Error('destination-IP pinning requires a private IPv4 address and path-evidence mode');
}
if (pathEvidenceMode) {
    if (!/^[a-z0-9][a-z0-9.-]{1,61}[a-z0-9]$/.test(evidenceBucket ?? '') || !/^[A-Za-z0-9][A-Za-z0-9_./=-]{0,255}$/.test(evidencePrefix ?? '')) {
        throw new Error('path-evidence mode requires valid run-scoped evidence bucket and prefix');
    }
}
if (rps < 1 || durationSeconds < 1 || connections < 1 || startEpoch < 0 || processStartSpacingSeconds < 0 || processStartOffsetSeconds < 0) throw new Error('load inputs must be positive');
if (![1, 2, 4].includes(processesPerNode)) throw new Error('--processes-per-node must be 1, 2, or 4');
if (rps % processesPerNode !== 0 || connections % processesPerNode !== 0) {
    throw new Error('RPS and connections must divide evenly across oha processes');
}

const pool = readFileSync(poolPath);
const manifest = JSON.parse(readFileSync(manifestPath, 'utf8'));
const poolSha256 = createHash('sha256').update(pool).digest('hex');
if (!/^[0-9a-f]{64}$/.test(manifest.sha256) || poolSha256 !== manifest.sha256) {
    throw new Error('local payload pool SHA-256 does not match its manifest');
}
if (optionValue('--payload-pool') && manifest.runtimeSelection !== 'oha -Z random sampling with replacement') {
    throw new Error('custom payload pool must explicitly declare oha sampling-with-replacement semantics');
}
const payloadGzipBase64 = gzipSync(pool, { level: 9 }).toString('base64');
const encodedPayloadBytes = Buffer.byteLength(payloadGzipBase64);
if (encodedPayloadBytes > TRANSFER_PROBE_BYTES) {
    throw new Error(`encoded payload is ${encodedPayloadBytes} bytes, above the verified 20 KiB transfer size`);
}
const caCertificate = connectionPathMode ? readFileSync(caCertificatePath) : Buffer.alloc(0);
const caCertificateSha256 = connectionPathMode ? createHash('sha256').update(caCertificate).digest('hex') : '';
const caCertificateBase64 = connectionPathMode ? caCertificate.toString('base64') : '';

mkdirSync(outputDir, { recursive: true });
const transferProbe = await runTransferProbe();
let targetHostHeader = targetIp || directTargetIp ? targetBaseUrl.slice('http://'.length) : '';
if (connectionPathMode) targetHostHeader = tlsServerName;
const targetConnectBaseUrl = connectionPathMode ? targetConnectBaseUrlOption : directTargetIp ? `http://${directTargetIp}:8080` : targetIp ? `http://${targetIp}` : targetBaseUrl;
const command = [
    'sudo -n env',
    `TARGET_BASE_URL='${targetBaseUrl}'`,
    `RUN_ID='${runId}'`,
    `QUERY_PER_SECOND='${rps}'`,
    `DURATION_SECONDS='${durationSeconds}'`,
    `CONNECTIONS='${connections}'`,
    `PROCESSES_PER_NODE='${processesPerNode}'`,
    `PROCESS_START_SPACING_SECONDS='${processStartSpacingSeconds}'`,
    `PROCESS_START_OFFSET_SECONDS='${processStartOffsetSeconds}'`,
    `EXPERIMENT_MODE='${experimentMode}'`,
    `TELEMETRY_INTERVAL_SECONDS='${pathEvidenceMode ? 1 : 5}'`,
    `START_EPOCH='${startEpoch}'`,
    `NODE_ID='${nodeId}'`,
    `INSTANCE_ID='${instanceId}'`,
    `TARGET_PATH='${targetPath}'`,
	`STAGE_LABEL='${stageLabel}'`,
	`REPETITION='${repetition}'`,
	`INSTRUMENTATION='${instrumentation}'`,
    `TARGET_CONNECT_BASE_URL='${targetConnectBaseUrl}'`,
    `TARGET_HOST_HEADER='${targetHostHeader}'`,
    `OHA_HTTP_VERSION='${connectionPathMode ? 2 : '1.1'}'`,
    `OHA_PARALLEL='1'`,
    `TLS_SERVER_NAME='${tlsServerName ?? ''}'`,
    `CA_CERTIFICATE_SHA256='${caCertificateSha256}'`,
    `CA_CERTIFICATE_BASE64='${caCertificateBase64}'`,
    `EVIDENCE_BUCKET='${evidenceBucket ?? ''}'`,
    `EVIDENCE_PREFIX='${evidencePrefix ?? ''}'`,
    `EXPECTED_POOL_SHA256='${poolSha256}'`,
    `PAYLOAD_GZIP_BASE64='${payloadGzipBase64}'`,
    '/opt/loop-ad-phase1/run-ec2-oha-worker.sh',
].join(' ');
const timeoutSeconds = durationSeconds + (connectionPathMode ? 900 : 300);
const { commandId, invocation, observation } = await runSsmCommand(
    [command],
    timeoutSeconds,
    `loop-ad ${runId} oha ${rps}rps ${durationSeconds}s`,
    (started) => recordPhase7CommandStarted('ssm-command-started.json', 'phase7-oha-load-command', started),
);

const stdout = invocation.StandardOutputContent ?? '';
const stderr = invocation.StandardErrorContent ?? '';
writeFileSync(join(outputDir, 'ssm-stderr.log'), stderr, 'utf8');
const invocationPath = join(outputDir, 'ssm-invocation.json');
const invocationRecord = {
    commandId,
    instanceId,
    status: invocation.Status,
    statusDetails: invocation.StatusDetails,
    responseCode: invocation.ResponseCode,
    executionStartDateTime: invocation.ExecutionStartDateTime,
    executionEndDateTime: invocation.ExecutionEndDateTime,
    rps,
    durationSeconds,
    connections,
    processesPerNode,
    processStartSpacingSeconds,
    processStartOffsetSeconds,
    experimentMode,
    targetPath,
	stageLabel,
	repetition,
	instrumentation,
    targetIp: targetIp ?? null,
	directTargetIp: directTargetIp ?? null,
    targetHostHeader: targetHostHeader || null,
    targetConnectBaseUrl,
    tlsServerName: tlsServerName ?? null,
    caCertificateSha256: caCertificateSha256 || null,
    nodeId,
    evidenceBucket: evidenceBucket ?? null,
    evidencePrefix: evidencePrefix ?? null,
    startEpoch,
    poolSha256,
    encodedPayloadBytes,
    commandBytes: Buffer.byteLength(command),
    transferProbe,
    observation,
    artifactDownloadObservation: null,
};
writeFileSync(invocationPath, `${JSON.stringify(invocationRecord, null, 2)}\n`, 'utf8');

const summaryLine = stdout.split('\n').find((line) => line.startsWith('OHA_SUMMARY='));
const artifactLine = stdout.split('\n').find((line) => line.startsWith('ARTIFACT_TGZ_BASE64='));
const artifactS3Line = stdout.split('\n').find((line) => line.startsWith('ARTIFACT_S3_URI='));
if (!summaryLine || (!artifactLine && !artifactS3Line)) {
    writeFileSync(join(outputDir, 'ssm-stdout-truncated.log'), stdout, 'utf8');
    throw new Error(`SSM output did not contain a complete artifact; status=${invocation.Status}.`);
}

const summary = JSON.parse(summaryLine.slice('OHA_SUMMARY='.length));
const archivePath = join(outputDir, 'artifacts.tgz');
if (artifactS3Line) {
    const artifactS3Uri = artifactS3Line.slice('ARTIFACT_S3_URI='.length);
    const expectedArtifactS3Uri = `s3://${evidenceBucket}/${evidencePrefix.replace(/\/$/, '')}/${nodeId}/artifacts.tgz`;
    if (artifactS3Uri !== expectedArtifactS3Uri) throw new Error('worker returned an unexpected S3 artifact URI');
    const artifactDownloadObservation = {
        absoluteDeadline: new Date(Date.now() + S3_ARTIFACT_DOWNLOAD_DEADLINE_MS).toISOString(),
        transientRetries: [],
    };
    invocationRecord.artifactDownloadObservation = artifactDownloadObservation;
    try {
        await downloadS3Artifact(artifactS3Uri, archivePath, artifactDownloadObservation);
    } finally {
        writeFileSync(invocationPath, `${JSON.stringify(invocationRecord, null, 2)}\n`, 'utf8');
    }
} else {
    writeFileSync(archivePath, Buffer.from(artifactLine.slice('ARTIFACT_TGZ_BASE64='.length), 'base64'));
}
execFileSync('tar', ['-xzf', archivePath, '-C', outputDir]);
const extractedSummary = JSON.parse(readFileSync(join(outputDir, 'oha-summary.json'), 'utf8'));
if (JSON.stringify(summary) !== JSON.stringify(extractedSummary)) {
    throw new Error('SSM summary does not match the extracted artifact.');
}
unlinkSync(archivePath);

process.stdout.write(`${JSON.stringify({
    commandId,
    status: invocation.Status,
    responseCode: invocation.ResponseCode,
    summary,
    outputDir,
}, null, 2)}\n`);
if (invocation.Status !== 'Success' || invocation.ResponseCode !== 0) {
    process.exitCode = 1;
}

async function runTransferProbe() {
    const probe = 'p'.repeat(TRANSFER_PROBE_BYTES);
    const expectedSha256 = createHash('sha256').update(probe).digest('hex');
    const remotePath = `/tmp/loop-ad-phase1/${runId}-ssm-transfer-probe`;
    const commands = [
        'mkdir -p /tmp/loop-ad-phase1',
        `printf '%s' '${probe}' > ${remotePath}`,
        `wc -c ${remotePath}`,
        `sha256sum ${remotePath}`,
        `rm -f ${remotePath}`,
    ];
    const { commandId, invocation, observation } = await runSsmCommand(
        commands,
        60,
        `loop-ad ${runId} 20KiB SSM transfer probe`,
        (started) => recordPhase7CommandStarted(
            'ssm-transfer-probe-started.json',
            'phase7-ssm-transfer-probe',
            started,
        ),
    );
    const lines = (invocation.StandardOutputContent ?? '').trim().split('\n');
    const remoteBytes = Number(lines[0]?.trim().split(/\s+/)[0]);
    const remoteSha256 = lines[1]?.trim().split(/\s+/)[0] ?? null;
    const result = {
        checkedAt: new Date().toISOString(),
        commandId,
        status: invocation.Status,
        responseCode: invocation.ResponseCode,
        probeBytes: TRANSFER_PROBE_BYTES,
        parametersJsonBytes: Buffer.byteLength(JSON.stringify({ commands, executionTimeout: ['60'] })),
        expectedSha256,
        remoteBytes,
        remoteSha256,
        observation,
        passed: invocation.Status === 'Success' && invocation.ResponseCode === 0 &&
            remoteBytes === TRANSFER_PROBE_BYTES && remoteSha256 === expectedSha256,
    };
    writeFileSync(join(outputDir, 'ssm-transfer-probe.json'), `${JSON.stringify(result, null, 2)}\n`, 'utf8');
    if (!result.passed) {
        throw new Error(`20 KiB SSM transfer probe failed: ${invocation.StandardErrorContent ?? invocation.Status}`);
    }
    return result;
}

async function runSsmCommand(commands, timeoutSeconds, comment, onStarted = () => {}) {
    // SendCommand has no idempotency token. Keep both this caller and the AWS
    // CLI to one API attempt so an accepted response loss cannot create a
    // second remote load command.
    const sendResponse = awsJson([
        'ssm', 'send-command', '--region', REGION,
        '--document-name', 'AWS-RunShellScript',
        '--instance-ids', instanceId,
        '--timeout-seconds', timeoutSeconds.toString(),
        '--parameters', JSON.stringify({
            commands,
            executionTimeout: [timeoutSeconds.toString()],
        }),
        '--comment', comment,
    ]);
    const commandId = sendResponse.Command.CommandId;
    onStarted({ commandId, comment });
    const deadline = Date.now() + timeoutSeconds * 1_000;
    const observation = {
        absoluteDeadline: new Date(deadline).toISOString(),
        transientRetries: [],
    };
    let invocation;
    while (Date.now() < deadline) {
        await sleep(Math.min(2_000, Math.max(1, deadline - Date.now())));
        if (Date.now() >= deadline) break;
        invocation = await getCommandInvocation([
            'ssm', 'get-command-invocation', '--region', REGION,
            '--command-id', commandId, '--instance-id', instanceId,
        ], deadline, observation);
        if (TERMINAL_SSM_STATUSES.has(invocation.Status)) {
            return { commandId, invocation, observation };
        }
        if (!ACTIVE_SSM_STATUSES.has(invocation.Status)) throw new Error(`SSM command ${commandId} returned unknown status ${invocation.Status}`);
    }
    throw new Error(`SSM command ${commandId} did not finish before the local deadline.`);
}

function recordPhase7CommandStarted(fileName, kind, { commandId, comment }) {
    if (!/^run_[0-9]{8}_[0-9]{6}_phase7_(?:warmup|score)$/.test(runId) ||
        !['warmup', 'score'].includes(stageLabel)) return;
    writeFileSync(join(outputDir, fileName), `${JSON.stringify({
        schemaVersion: 1,
        kind,
        runId,
        stageLabel,
        nodeId,
        instanceId,
        commandId,
        comment,
        recordedAt: new Date().toISOString(),
    }, null, 2)}\n`, 'utf8');
}

function awsJson(args, { timeout, shortCliTimeouts = false } = {}) {
    return JSON.parse(execFileSync('aws', [
        ...args,
        ...(shortCliTimeouts ? AWS_CLI_SHORT_TIMEOUT_ARGS : []),
        '--output', 'json', '--no-cli-pager',
    ], {
        encoding: 'utf8',
        maxBuffer: 32 * 1024 * 1024,
        env: { ...process.env, ...AWS_CLI_SINGLE_ATTEMPT_ENV },
        ...(timeout === undefined ? {} : { timeout }),
    }));
}

async function getCommandInvocation(args, deadline, observation) {
    return runBoundedAwsObservation({
        operation: 'ssm:GetCommandInvocation',
        deadlineEpochMs: deadline,
        invocationMayNotExist: true,
        transientRetries: observation.transientRetries,
        action: ({ remainingMs }) => awsJson(args, {
            timeout: remainingMs,
            shortCliTimeouts: true,
        }),
    });
}

async function downloadS3Artifact(source, destination, observation) {
    if (!source.startsWith('s3://') || destination !== join(outputDir, 'artifacts.tgz')) {
        throw new Error('artifact retry is restricted to the exact S3-to-local download');
    }
    const deadline = Date.parse(observation.absoluteDeadline);
    return runBoundedAwsObservation({
        operation: 's3:GetObject-artifact-download',
        deadlineEpochMs: deadline,
        transientRetries: observation.transientRetries,
        action: ({ remainingMs }) => execFileSync('aws', [
            's3', 'cp', source, destination,
            '--region', REGION,
            '--only-show-errors',
            ...AWS_CLI_SHORT_TIMEOUT_ARGS,
            '--no-cli-pager',
        ], {
            env: { ...process.env, ...AWS_CLI_SINGLE_ATTEMPT_ENV },
            timeout: remainingMs,
        }),
    });
}

function requiredOption(name) {
    const value = optionValue(name);
    if (!value) throw new Error(`${name} is required.`);
    return value;
}

function optionValue(name) {
    const index = process.argv.indexOf(name);
    return index >= 0 ? process.argv[index + 1] : undefined;
}

function requiredInteger(name) {
    const value = Number(requiredOption(name));
    if (!Number.isInteger(value)) throw new Error(`${name} must be an integer.`);
    return value;
}

function integerOption(name, defaultValue) {
    const raw = optionValue(name);
    const value = raw === undefined ? defaultValue : Number(raw);
    if (!Number.isInteger(value)) throw new Error(`${name} must be an integer.`);
    return value;
}

function optionalInteger(name) {
    const raw = optionValue(name);
    if (raw === undefined) return undefined;
    const value = Number(raw);
    if (!Number.isInteger(value)) throw new Error(`${name} must be an integer.`);
    return value;
}

function sleep(milliseconds) {
    return new Promise((resolve) => setTimeout(resolve, milliseconds));
}

function isPrivateIpv4(value) {
    const octets = value.split('.').map(Number);
    if (octets.length !== 4 || octets.some((octet) => !Number.isInteger(octet) || octet < 0 || octet > 255)) return false;
    return octets[0] === 10 || (octets[0] === 172 && octets[1] >= 16 && octets[1] <= 31) || (octets[0] === 192 && octets[1] === 168);
}

function isAllowedTargetPath(value) {
	return value === '/events' || value === '/__generator_control' || value === '/__proxy_control' || value === '/__collector_control' ||
		value === '/__decode_control' || /^\/__delay_control\?delay=(?:0|50|100|200|300)$/.test(value) ||
		/^\/__batch_control\?ack_delay=(?:0|20|50)$/.test(value);
}
