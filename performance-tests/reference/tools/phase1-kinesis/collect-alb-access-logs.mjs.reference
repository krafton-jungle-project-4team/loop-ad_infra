#!/usr/bin/env node

import { execFileSync } from 'node:child_process';
import { createHash } from 'node:crypto';
import { mkdirSync, readFileSync, writeFileSync } from 'node:fs';
import { basename, join } from 'node:path';

const REGION = 'ap-northeast-2';
const bucket = requiredOption('--bucket');
const prefix = requiredOption('--prefix');
const outputDir = requiredOption('--output-dir');
const waitSeconds = Number(optionValue('--wait-seconds') ?? 600);
const notBefore = optionValue('--not-before');
const notBeforeMs = notBefore ? Date.parse(notBefore) : null;
if (!/^[a-z0-9][a-z0-9.-]{1,61}[a-z0-9]$/.test(bucket)) throw new Error('invalid bucket');
if (!/^phase1-kinesis-(?:alb-warmup|tcp-alb-path-diagnosis|admission-scaleout|protocol-crossover|connection-path)-[0-9]{8}T[0-9]{6}Z\/run_[0-9]{8}_[0-9]{6}_[a-z0-9_-]+$/.test(prefix)) throw new Error('invalid access-log prefix');
if (!Number.isInteger(waitSeconds) || waitSeconds < 0 || waitSeconds > 900) throw new Error('invalid wait seconds');
if (notBefore && !Number.isFinite(notBeforeMs)) throw new Error('invalid --not-before timestamp');

mkdirSync(join(outputDir, 'raw'), { recursive: true });
const deadline = Date.now() + waitSeconds * 1_000;
let objects = [];
do {
    objects = awsJson(['s3api', 'list-objects-v2', '--region', REGION, '--bucket', bucket, '--prefix', `${prefix}/AWSLogs/`]).Contents ?? [];
    const fresh = objects.some((object) => object.Key.endsWith('.log.gz') && (notBeforeMs === null || Date.parse(object.LastModified) >= notBeforeMs));
    if (fresh) break;
    if (Date.now() >= deadline) break;
    await new Promise((resolve) => setTimeout(resolve, 15_000));
} while (true);

const manifestObjects = [];
for (const object of objects.filter((item) => item.Key.endsWith('.log.gz')).toSorted((a, b) => a.Key.localeCompare(b.Key))) {
    const localName = basename(object.Key);
    const localPath = join(outputDir, 'raw', localName);
    execFileSync('aws', ['s3api', 'get-object', '--region', REGION, '--bucket', bucket, '--key', object.Key, localPath, '--no-cli-pager'], { stdio: ['ignore', 'ignore', 'inherit'] });
    const bytes = readFileSync(localPath);
    manifestObjects.push({ key: object.Key, localName, size: bytes.length, etag: object.ETag, lastModified: object.LastModified,
        sha256: createHash('sha256').update(bytes).digest('hex') });
}
const result = { collectedAt: new Date().toISOString(), region: REGION, bucket, prefix, waitSeconds, objectCount: manifestObjects.length,
    notBefore: notBefore ?? null,
    freshObjectObserved: notBeforeMs === null || manifestObjects.some((object) => Date.parse(object.lastModified) >= notBeforeMs),
    rawObjectsPreservedUnchanged: true, objects: manifestObjects };
result.passed = result.objects.length > 0 && result.freshObjectObserved;
writeFileSync(join(outputDir, 'raw-manifest.json'), `${JSON.stringify(result, null, 2)}\n`, 'utf8');
process.stdout.write(`${JSON.stringify(result, null, 2)}\n`);
if (!result.passed) process.exitCode = 2;

function awsJson(args) { return JSON.parse(execFileSync('aws', [...args, '--output', 'json', '--no-cli-pager'], { encoding: 'utf8', maxBuffer: 64 * 1024 * 1024 })); }
function requiredOption(name) { const value = optionValue(name); if (!value) throw new Error(`${name} is required`); return value; }
function optionValue(name) { const index = process.argv.indexOf(name); return index < 0 ? undefined : process.argv[index + 1]; }
