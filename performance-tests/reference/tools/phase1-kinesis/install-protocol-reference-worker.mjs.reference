#!/usr/bin/env node

import { createHash } from 'node:crypto';
import { execFileSync } from 'node:child_process';
import { readFileSync, writeFileSync } from 'node:fs';

const REGION = 'ap-northeast-2';
const instanceIds = requiredOption('--instance-ids').split(',');
const output = requiredOption('--output');
if (instanceIds.length !== 4 || new Set(instanceIds).size !== 4 || instanceIds.some((id) => !/^i-[0-9a-f]+$/.test(id))) {
    throw new Error('exactly four unique generator instance IDs are required');
}
const workerPath = new URL('./run-ec2-reference-worker.sh', import.meta.url);
const worker = readFileSync(workerPath);
const sha256 = createHash('sha256').update(worker).digest('hex');
const encoded = worker.toString('base64');
const remotePath = '/opt/loop-ad-phase1/run-ec2-reference-worker.sh';
const filter = 'tcp port 443 and ((tcp[tcpflags] & (tcp-syn|tcp-rst) != 0) or ((tcp[tcpflags] & tcp-fin != 0) and (ip[2:2] - ((ip[0] & 0x0f) << 2) - ((tcp[12] & 0xf0) >> 2) = 0)))';
const quicFilter = 'udp port 443';
const command = `set -euo pipefail
umask 077
temporary=/tmp/loopad-reference-worker-install
printf '%s' '${encoded}' | base64 -d > "$temporary"
test "$(sha256sum "$temporary" | awk '{print $1}')" = '${sha256}'
sudo -n install -m 0755 "$temporary" '${remotePath}'
rm -f "$temporary"
test "$(sha256sum '${remotePath}' | awk '{print $1}')" = '${sha256}'
sudo -n tcpdump -d '${filter}' >/dev/null
sudo -n tcpdump -d '${quicFilter}' >/dev/null
printf 'WORKER_SHA256=%s\n' '${sha256}'`;
const sent = aws(['ssm', 'send-command', '--region', REGION, '--document-name', 'AWS-RunShellScript',
    '--instance-ids', ...instanceIds, '--parameters', JSON.stringify({ commands: [command] }),
    '--timeout-seconds', '120', '--comment', 'install run-scoped protocol reference worker']);
const commandId = sent.Command.CommandId;
const deadline = Date.now() + 120_000;
let invocations = [];
while (Date.now() < deadline) {
    await new Promise((resolve) => setTimeout(resolve, 2_000));
    invocations = aws(['ssm', 'list-command-invocations', '--region', REGION, '--command-id', commandId, '--details']).CommandInvocations ?? [];
    if (invocations.length === 4 && invocations.every((item) => !['Pending', 'InProgress', 'Delayed'].includes(item.Status))) break;
}
const checks = {
    exactInvocations: invocations.length === 4,
    allSucceeded: invocations.length === 4 && invocations.every((item) => item.Status === 'Success'),
    shaConfirmed: invocations.length === 4 && invocations.every((item) => item.CommandPlugins?.some((plugin) => plugin.Output?.includes(`WORKER_SHA256=${sha256}`))),
};
const result = { installedAt: new Date().toISOString(), region: REGION, instanceIds, remotePath, sha256,
    commandId, invocations: invocations.map((item) => ({ instanceId: item.InstanceId, status: item.Status,
        responseCode: item.CommandPlugins?.[0]?.ResponseCode, output: item.CommandPlugins?.[0]?.Output })),
    checks, passed: Object.values(checks).every(Boolean) };
writeFileSync(output, `${JSON.stringify(result, null, 2)}\n`, 'utf8');
process.stdout.write(`${JSON.stringify(result, null, 2)}\n`);
if (!result.passed) process.exitCode = 2;

function aws(args) {
    const text = execFileSync('aws', [...args, '--output', 'json', '--no-cli-pager'], { encoding: 'utf8', maxBuffer: 32 * 1024 * 1024 });
    return JSON.parse(text);
}
function requiredOption(name) {
    const index = process.argv.indexOf(name);
    const value = index < 0 ? undefined : process.argv[index + 1];
    if (!value) throw new Error(`${name} is required`);
    return value;
}
