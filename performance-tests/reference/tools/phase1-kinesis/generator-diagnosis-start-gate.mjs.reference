#!/usr/bin/env node

import { readFileSync, writeFileSync } from 'node:fs';

const minimumWorkSeconds = { topology: 300, candidate: 900, stage: 300, cleanup: 0 };
const sessionId = requiredOption('--session-id');
const sessionPath = requiredOption('--session');
const action = requiredOption('--action');
const output = optionValue('--output');
const now = new Date(optionValue('--now') ?? Date.now());
const estimatedWorkSeconds = integerOption('--estimated-work-seconds', minimumWorkSeconds[action]);
if (!/^phase1-kinesis-generator-diagnosis-[0-9]{8}T[0-9]{6}Z$/.test(sessionId)) throw new Error('invalid session ID');
if (!Object.hasOwn(minimumWorkSeconds, action)) throw new Error('invalid action');
if (!Number.isFinite(now.getTime())) throw new Error('invalid now');

const session = JSON.parse(readFileSync(sessionPath, 'utf8'));
const startedAt = new Date(session.startedAt);
const startDeadline = deadline(session.runtime?.newWorkDeadline, startedAt, 100 * 60);
const cleanupDeadline = deadline(session.runtime?.cleanupDeadline, startedAt, 110 * 60);
const hardDeadline = deadline(session.runtime?.hardDeadline, startedAt, 120 * 60);
if (!(startedAt < startDeadline && startDeadline < cleanupDeadline && cleanupDeadline <= hardDeadline)) {
    throw new Error('invalid runtime deadline ordering');
}
const newWorkStopUsd = session.newWorkStopUsd ?? 28;
const incrementalHardCapUsd = session.incrementalHardCapUsd ?? 30;
const ageSeconds = (now.getTime() - startedAt.getTime()) / 1_000;
const projectedFinishAgeSeconds = ageSeconds + estimatedWorkSeconds;
let cost = null;
if (action !== 'cleanup') {
    const accrued = JSON.parse(readFileSync(requiredOption('--accrued-cost'), 'utf8'));
    const projected = JSON.parse(readFileSync(requiredOption('--projected-cost'), 'utf8'));
    const modeledAccruedUsd = accrued.projectedCumulativeUpperBoundUsd ?? accrued.runUpperBoundUsd;
    cost = {
        modeledAccruedUsd,
        projectedTotalUsd: projected.projectedCumulativeUpperBoundUsd,
        belowNewRunStop: Number.isFinite(modeledAccruedUsd) && modeledAccruedUsd < newWorkStopUsd,
        belowHardLimit: Number.isFinite(projected.projectedCumulativeUpperBoundUsd) && projected.projectedCumulativeUpperBoundUsd < incrementalHardCapUsd,
    };
}
const checks = {
    sessionIdentityMatches: session.sessionId === sessionId && session.region === 'ap-northeast-2',
    nonNegativeAge: ageSeconds >= 0,
    hardLifetimeOpen: now < hardDeadline,
    startWindowOpen: action === 'cleanup' || now < startDeadline,
    conservativeEstimateProvided: action === 'cleanup' || estimatedWorkSeconds >= minimumWorkSeconds[action],
    projectedFinishBeforeCleanup: action === 'cleanup' || new Date(now.getTime() + estimatedWorkSeconds * 1_000) <= cleanupDeadline,
    accruedBelowNewRunStop: action === 'cleanup' || cost.belowNewRunStop,
    projectedBelowHardLimit: action === 'cleanup' || cost.belowHardLimit,
};
const result = {
    checkedAt: now.toISOString(), sessionId, action,
    runtime: { startedAt: startedAt.toISOString(), ageSeconds, projectedFinishAgeSeconds,
        startDeadline: startDeadline.toISOString(), cleanupDeadline: cleanupDeadline.toISOString(), hardDeadline: hardDeadline.toISOString(),
        startDeadlineSeconds: (startDeadline - startedAt) / 1_000,
        cleanupDeadlineSeconds: (cleanupDeadline - startedAt) / 1_000, hardDeadlineSeconds: (hardDeadline - startedAt) / 1_000 },
    estimate: { estimatedWorkSeconds, minimumWorkSeconds: minimumWorkSeconds[action] },
    cost, checks, passed: Object.values(checks).every(Boolean),
};
const serialized = `${JSON.stringify(result, null, 2)}\n`;
if (output) writeFileSync(output, serialized, 'utf8');
process.stdout.write(serialized);
if (!result.passed) process.exitCode = 2;

function requiredOption(name) { const value = optionValue(name); if (!value) throw new Error(`${name} is required`); return value; }
function optionValue(name) { const index = process.argv.indexOf(name); return index < 0 ? undefined : process.argv[index + 1]; }
function integerOption(name, fallback) { const raw = optionValue(name); const value = raw === undefined ? fallback : Number(raw); if (!Number.isInteger(value) || value < 0) throw new Error(`${name} must be non-negative`); return value; }
function deadline(value, startedAt, fallbackSeconds) {
    const result = value ? new Date(value) : new Date(startedAt.getTime() + fallbackSeconds * 1_000);
    if (!Number.isFinite(result.getTime())) throw new Error('invalid runtime deadline');
    return result;
}
