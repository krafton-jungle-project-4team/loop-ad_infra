#!/usr/bin/env node

import { execFileSync } from 'node:child_process';
import { writeFileSync } from 'node:fs';

const REGION = 'ap-northeast-2';
const LOCATION = 'Asia Pacific (Seoul)';
const outputPath = requiredOption('--output');

const selections = {
    clickHouseR7g2xlargeHour: instancePrice('r7g.2xlarge'),
    producerC7g2xlargeHour: instancePrice('c7g.2xlarge'),
    kinesisProvisionedShardHour: selectQuery('AmazonKinesis', {
        operation: 'shardHourStorage',
        group: 'Provisioned shard hour',
    }),
    kinesisPutPayloadUnit: selectQuery('AmazonKinesis', {
        operation: 'PutRequest',
        group: 'Payload Units',
    }),
    ebsGp3GbMonth: selectQuery('AmazonEC2', {
        usagetype: 'APN2-EBS:VolumeUsage.gp3',
    }),
    ebsGp3ThroughputGibpsMonth: selectQuery('AmazonEC2', {
        usagetype: 'APN2-EBS:VolumeP-Throughput.gp3',
    }),
    lambdaArmGbSecond: selectQuery('AWSLambda', {
        usagetype: 'APN2-Lambda-GB-Second-ARM',
    }),
    lambdaArmRequest: selectQuery('AWSLambda', {
        usagetype: 'APN2-Request-ARM',
    }),
    secretsManagerSecretMonth: selectQuery('AWSSecretsManager', {
        usagetype: 'APN2-AWSSecretsManager-Secrets',
    }),
    secretsManagerApiRequest: selectQuery('AWSSecretsManager', {
        usagetype: 'APN2-AWSSecretsManagerAPIRequest',
    }),
    vpcEndpointHour: selectQuery('AmazonVPC', {
        usagetype: 'APN2-VpcEndpoint-Hours',
    }),
    publicIpv4Hour: selectQuery('AmazonVPC', {
        usagetype: 'APN2-PublicIPv4:InUseAddress',
    }),
};

const result = {
    schemaVersion: 1,
    asOf: new Date().toISOString(),
    region: REGION,
    location: LOCATION,
    source: 'AWS Price List GetProducts, public On-Demand USD',
    prices: Object.fromEntries(
        Object.entries(selections).map(([name, selection]) => [name, selection.price]),
    ),
    provenance: Object.fromEntries(
        Object.entries(selections).map(([name, selection]) => [name, {
            serviceCode: selection.serviceCode,
            sku: selection.sku,
            usageType: selection.attributes.usagetype,
            operation: selection.attributes.operation,
            unit: selection.dimension.unit,
            beginRange: selection.dimension.beginRange,
            endRange: selection.dimension.endRange,
            description: selection.dimension.description,
            pricePerUnitUsd: selection.dimension.pricePerUnit.USD,
        }]),
    ),
};

writeFileSync(outputPath, `${JSON.stringify(result, null, 2)}\n`, { encoding: 'utf8', mode: 0o600 });
process.stdout.write(`${JSON.stringify({
    asOf: result.asOf,
    region: result.region,
    prices: result.prices,
}, null, 2)}\n`);

function instancePrice(instanceType) {
    const matches = products('AmazonEC2', [
        filter('instanceType', instanceType),
        filter('location', LOCATION),
        filter('operatingSystem', 'Linux'),
        filter('tenancy', 'Shared'),
        filter('preInstalledSw', 'NA'),
        filter('capacitystatus', 'Used'),
    ]).filter((product) => product.product.productFamily === 'Compute Instance');
    return uniqueSelection(matches, { instanceType });
}

function products(serviceCode, filters) {
    const args = [
        'pricing', 'get-products',
        '--service-code', serviceCode,
        '--region', 'us-east-1',
        '--max-results', '100',
        '--output', 'json',
        '--no-cli-pager',
    ];
    if (filters.length > 0) args.push('--filters', ...filters);
    const response = JSON.parse(execFileSync('aws', args, {
        encoding: 'utf8',
        maxBuffer: 64 * 1024 * 1024,
    }));
    return response.PriceList.map((item) => ({ serviceCode, ...JSON.parse(item) }));
}

function selectQuery(serviceCode, expectedAttributes, beginRange = '0') {
    const queryFilters = [
        filter('location', LOCATION),
        ...Object.entries(expectedAttributes).map(([field, value]) => filter(field, value)),
    ];
    const matches = products(serviceCode, queryFilters).filter((product) => (
        Object.entries(expectedAttributes).every(
            ([key, value]) => product.product.attributes[key] === value,
        )
    ));
    return uniqueSelection(matches, expectedAttributes, beginRange);
}

function uniqueSelection(matches, expectedAttributes, beginRange = '0') {
    const dimensions = matches.flatMap((product) => (
        Object.values(product.terms.OnDemand ?? {}).flatMap((term) => (
            Object.values(term.priceDimensions ?? {}).map((dimension) => ({
                serviceCode: product.serviceCode,
                sku: product.product.sku,
                attributes: product.product.attributes,
                dimension,
                price: Number(dimension.pricePerUnit?.USD),
            }))
        ))
    )).filter((selection) => (
        selection.dimension.beginRange === beginRange
        && Number.isFinite(selection.price)
    ));
    if (dimensions.length !== 1) {
        throw new Error(
            `Expected one price for ${JSON.stringify(expectedAttributes)}, found ${dimensions.length}.`,
        );
    }
    return dimensions[0];
}

function filter(field, value) {
    return `Type=TERM_MATCH,Field=${field},Value=${value}`;
}

function requiredOption(name) {
    const index = process.argv.indexOf(name);
    const value = index >= 0 ? process.argv[index + 1] : undefined;
    if (!value) throw new Error(`${name} requires a value.`);
    return value;
}
