#!/usr/bin/env node

import { execFileSync } from 'node:child_process';
import { writeFileSync } from 'node:fs';
import { evaluateAlbWarmupCleanup } from './alb-warmup-cleanup.mjs';

const REGION = 'ap-northeast-2';
const sessionId = requiredOption('--session-id');
const runId = requiredOption('--run-id');
const bucketName = requiredOption('--bucket-name');
const output = requiredOption('--output');
if (!/^phase1-kinesis-alb-warmup-[0-9]{8}T[0-9]{6}Z$/.test(sessionId)) throw new Error('invalid session ID');
if (!/^run_[0-9]{8}_[0-9]{6}_[a-z0-9][a-z0-9_-]{0,31}$/.test(runId)) throw new Error('invalid run ID');
if (!/^[a-z0-9][a-z0-9.-]{1,61}[a-z0-9]$/.test(bucketName)) throw new Error('invalid bucket name');

const inventory = {
    runStack: maybe(['cloudformation', 'describe-stacks', '--region', REGION, '--stack-name', 'LoopAdPerfPhase1KinesisAlbWarmupStack'])?.Stacks?.[0] ?? null,
    streamStack: maybe(['cloudformation', 'describe-stacks', '--region', REGION, '--stack-name', 'LoopAdPerfPhase1KinesisAlbWarmupStreamStack'])?.Stacks?.[0] ?? null,
    instances: aws(['ec2', 'describe-instances', '--region', REGION, '--filters', `Name=tag:SessionId,Values=${sessionId}`, 'Name=instance-state-name,Values=pending,running,stopping,stopped,shutting-down']).Reservations.flatMap((reservation) => reservation.Instances),
    autoScalingGroups: (aws(['autoscaling', 'describe-auto-scaling-groups', '--region', REGION, '--auto-scaling-group-names', 'perf-phase1-loop-ad-collector', 'perf-phase1-loop-ad-load-generator']).AutoScalingGroups ?? []),
    launchTemplates: aws(['ec2', 'describe-launch-templates', '--region', REGION, '--filters', `Name=tag:SessionId,Values=${sessionId}`]).LaunchTemplates ?? [],
    loadBalancers: maybe(['elbv2', 'describe-load-balancers', '--region', REGION, '--names', 'perf-phase1-loop-ad-alb'])?.LoadBalancers ?? [],
    targetGroups: maybe(['elbv2', 'describe-target-groups', '--region', REGION, '--names', 'perf-phase1-loop-ad-collector'])?.TargetGroups ?? [],
    vpcs: aws(['ec2', 'describe-vpcs', '--region', REGION, '--filters', `Name=tag:SessionId,Values=${sessionId}`]).Vpcs ?? [],
    kinesisStream: maybe(['kinesis', 'describe-stream-summary', '--region', REGION, '--stream-name', 'perf-phase1-loop-ad-events'])?.StreamDescriptionSummary ?? null,
    ecsClusters: aws(['ecs', 'describe-clusters', '--region', REGION, '--clusters', 'perf-phase1-loop-ad-collector-cluster']).clusters ?? [],
    logGroups: (aws(['logs', 'describe-log-groups', '--region', REGION, '--log-group-name-prefix', '/loop-ad/perf-phase1/']).logGroups ?? []),
    alarms: (aws(['cloudwatch', 'describe-alarms', '--region', REGION, '--alarm-name-prefix', 'perf-phase1-loop-ad']).MetricAlarms ?? []),
    iamRoles: ['loop-ad-perf-phase1-collector-instance', 'loop-ad-perf-phase1-collector-task', 'loop-ad-perf-phase1-collector-execution', 'loop-ad-perf-phase1-load-generator-instance'].filter((name) => maybe(['iam', 'get-role', '--role-name', name]) !== null),
    ecrImages: (aws(['ecr', 'list-images', '--region', REGION, '--repository-name', 'loop-ad/event-collector', '--filter', 'tagStatus=TAGGED']).imageIds ?? []).filter((image) => image.imageTag?.startsWith(`${runId}-`)),
    s3: readS3(bucketName),
};
const result = { sessionId, runId, region: REGION, ...evaluateAlbWarmupCleanup(inventory) };
writeFileSync(output, `${JSON.stringify(result, null, 2)}\n`, 'utf8');
process.stdout.write(`${JSON.stringify(result, null, 2)}\n`);
if (!result.passed) process.exitCode = 2;

function readS3(bucket) {
    const exists = maybe(['s3api', 'head-bucket', '--bucket', bucket]) !== null;
    if (!exists) return { bucketExists: false, objects: [], multipartUploads: [], policyExists: false };
    return { bucketExists: true,
        objects: aws(['s3api', 'list-objects-v2', '--region', REGION, '--bucket', bucket]).Contents ?? [],
        multipartUploads: aws(['s3api', 'list-multipart-uploads', '--region', REGION, '--bucket', bucket]).Uploads ?? [],
        policyExists: maybe(['s3api', 'get-bucket-policy', '--region', REGION, '--bucket', bucket]) !== null };
}
function aws(args) { return JSON.parse(execFileSync('aws', [...args, '--output', 'json', '--no-cli-pager'], { encoding: 'utf8', maxBuffer: 64 * 1024 * 1024 })); }
function maybe(args) { try { return aws(args); } catch (error) { const text = `${error.stderr ?? ''}`; if (/does not exist|not found|NoSuch|ValidationError|404|NotFound/i.test(text)) return null; throw error; } }
function requiredOption(name) { const index = process.argv.indexOf(name); const value = index < 0 ? undefined : process.argv[index + 1]; if (!value) throw new Error(`${name} is required`); return value; }
