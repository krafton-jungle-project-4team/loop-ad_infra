    it('embeds only the oha worker within EC2 user-data limits', () => {
        const template = Template.fromStack(synthPerfPhase1Kinesis());
        const launchTemplate = Object.values(resourcesOf(template)).find((resource) => (
            resource.Type === 'AWS::EC2::LaunchTemplate' &&
            (resource.Properties?.LaunchTemplateData as Record<string, unknown>)?.InstanceType === 'c6in.large'
        ));
        const launchTemplateData = launchTemplate?.Properties?.LaunchTemplateData as Record<string, unknown>;
        const userData = launchTemplateData.UserData as { 'Fn::Base64': string };
        const decodedUserData = userData['Fn::Base64'];

        expect(Buffer.byteLength(decodedUserData, 'utf8')).toBeLessThanOrEqual(16_384);
        expect(decodedUserData).toContain('dnf install -y jq awscli-2');
        expect(decodedUserData).not.toContain('yum install');
        expect(decodedUserData).not.toContain('generate-payload-pool.py');
		expect(decodedUserData).toContain('bash /tmp/install-loopad-load-tools.sh');

        const embedded = [...decodedUserData.matchAll(/printf '%s' '([^']+)' \| base64 -d \| gzip -d > (\/tmp\/install-loopad-load-tools\.sh)/g)];
        expect(embedded).toHaveLength(1);
        for (const match of embedded) {
            const compressed = match[1];
            const destination = match[2];
            if (!compressed || !destination) {
                throw new Error('Malformed embedded phase 1 tool command.');
            }
			const installer = gunzipSync(Buffer.from(compressed, 'base64')).toString('utf8');
			for (const filename of ['run-ec2-oha-worker.sh']) {
				const source = readFileSync(join(ROOT, 'performance-tests/phase1-kinesis', filename), 'utf8');
				expect(installer).toContain(`/opt/loop-ad-phase1/${filename}`);
				expect(installer).toContain(source);
			}
			expect(installer).not.toContain('run-ec2-reference-worker.sh');
        }
    });

    it('limits the task role to PutRecord on the exact stream', () => {
        const template = Template.fromStack(synthPerfPhase1Kinesis());
        const resources = resourcesOf(template);
        const roleEntry = Object.entries(resources).find(([, resource]) => (
            resource.Type === 'AWS::IAM::Role' && resource.Properties?.RoleName === 'loop-ad-perf-phase1-collector-task'
        ));
        expect(roleEntry).toBeDefined();
        const [roleLogicalId] = roleEntry ?? [];
        const taskPolicies = Object.values(resources).filter((resource) => {
            if (resource.Type !== 'AWS::IAM::Policy') {
                return false;
            }
            const roles = resource.Properties?.Roles as Array<{ Ref?: string }> | undefined;
            return roles?.some((role) => role.Ref === roleLogicalId) ?? false;
        });

        expect(taskPolicies).toHaveLength(1);
        expect(taskPolicies[0]?.Properties?.PolicyDocument).toEqual({
            Version: '2012-10-17',
            Statement: [
                {
                    Action: 'kinesis:PutRecord',
                    Effect: 'Allow',
                    Resource: {
                        'Fn::Join': [
                            '',
                            [
                                'arn:',
                                { Ref: 'AWS::Partition' },
                                ':kinesis:ap-northeast-2:123456789012:stream/perf-phase1-loop-ad-events',
                            ],
                        ],
                    },
                },
            ],
        });
        const role = roleEntry?.[1];
        expect(role?.Properties?.ManagedPolicyArns).toBeUndefined();
        expect(role?.Properties?.AssumeRolePolicyDocument).toEqual({
            Version: '2012-10-17',
            Statement: [
                {
                    Action: 'sts:AssumeRole',
                    Condition: {
                        ArnLike: {
                            'aws:SourceArn': {
                                'Fn::Join': ['', ['arn:', { Ref: 'AWS::Partition' }, ':ecs:ap-northeast-2:123456789012:*']],
                            },
                        },
                        StringEquals: { 'aws:SourceAccount': '123456789012' },
                    },
                    Effect: 'Allow',
                    Principal: { Service: 'ecs-tasks.amazonaws.com' },
                },
            ],
        });
        expect(JSON.stringify(taskPolicies)).not.toContain('kinesis:PutRecords');
        expect(JSON.stringify(taskPolicies)).not.toContain('kms:');
    });

