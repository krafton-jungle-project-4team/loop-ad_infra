#!/usr/bin/env node

export const CONNECTION_PATH_EXPERIMENT_MODE = 'connection-path-crossover';
export const HAPROXY_IMAGE = 'haproxy:3.2.4-alpine@sha256:1cbc82126de93c9548a7fc31141c361961ec93a8badf77c8c3e8e211d007790d';

export function buildConnectionPathCrossoverPlan(seed = 20_260_715) {
    if (!Number.isSafeInteger(seed) || seed < 1) throw new Error('seed must be a positive safe integer');
    const physicalConnectionContract = {
        logicalDevices: 12_000,
        physicalConnections: 12_000,
        streamsPerConnection: 1,
        ohaParallel: 1,
        protocolFallbacksAllowed: 0,
        minimumObservedFraction: 0.99,
    };
    const workload30k = workload(30_000, physicalConnectionContract.physicalConnections);
    const workload50k = workload(50_000, physicalConnectionContract.physicalConnections);
    const topologies = {
        T0: {
            role: 'generator-fixed-control', loadBalancer: 'alb', listener: 'HTTPS', clientProtocol: 'h2',
            route: '/__generator_control', target: 'fixed-response', targetProtocol: null,
        },
        T1: {
            role: 'actual', loadBalancer: 'alb', listener: 'HTTPS', clientProtocol: 'h2', route: '/events',
            target: 'collector', targetProtocol: 'HTTP2', routingAlgorithm: 'round_robin',
        },
        T2: {
            role: 'actual', loadBalancer: 'nlb', listener: 'TCP', clientProtocol: 'h2', route: '/events',
            target: 'collector', targetProtocol: 'TLS_H2', crossZone: true, connectionPinnedForLifetime: true,
        },
        T3: {
            role: 'actual', loadBalancer: 'nlb', listener: 'TCP', clientProtocol: 'h2', route: '/events',
            target: 'haproxy', targetProtocol: 'TLS_H2', crossZone: true,
            proxy: {
                fleetSize: 2, availabilityZones: ['ap-northeast-2a', 'ap-northeast-2c'],
                instanceType: 'c6in.xlarge', image: HAPROXY_IMAGE, frontendProtocol: 'TLS_H2',
                backendProtocol: 'H2C', backendAlgorithm: 'leastconn', retries: 0, redispatch: false,
                requestBuffering: false, controlRoute: '/__proxy_control', controlMinimumRps: 50_000,
            },
        },
    };
    return {
        schemaVersion: 1,
        seed,
        immutable: {
            region: 'ap-northeast-2', candidate: 'go-batch', kinesisShards: 80,
            collectors: 4, collectorInstanceType: 'c6i.xlarge', collectorTasksPerHost: 1,
            applicationMaxInFlight: 2048, sdkMaxConnections: 1024,
            generators: 4, generatorInstanceType: 'c6in.large', generatorAzCounts: { 'ap-northeast-2a': 2, 'ap-northeast-2c': 2 },
            processesPerNode: 2, totalProcesses: 8, timeoutSeconds: 10, acknowledgement: 'kinesis-final-ack',
        },
        physicalConnectionContract,
        workload30k,
        workload50k,
        topologies,
        topologyOrder: deterministicShuffle(['T1', 'T2', 'T3'], seed),
        warmup: { durationSeconds: 900, scored: false, processStartSpacingSeconds: 5 },
        measured: { durationSeconds: 300, independentRepetitions: 3 },
        synchronizedDiagnostic: { processStartSpacingSeconds: 0, exploratoryRepetitions: 1, boundaryRepetitions: 3 },
        connectionCardinalityDiagnostic: [6_000, 12_000, 24_000],
        promotion30k: {
            repetitions: 3, minimumOfferedAccuracy: 0.99, minimumAchievedFraction: 0.99,
            maximumTransportErrorFraction: 0.001, maximumUnexpectedStatusFraction: 0.001,
            maximumTargetP95Ms: 500, minimumPhysicalConnectionFraction: 0.99,
            maximumKinesisThrottleOrFailure: 0, maximumTaskRestartOrFatal: 0, maximumEvidenceGaps: 0,
        },
        fiftyK: { conditional: true, warmupSeconds: 900, measuredSeconds: 300, initialRepetitions: 1, successRepetitions: 3 },
    };
}

export function workload(totalRps, physicalConnections) {
    if (!Number.isSafeInteger(totalRps) || totalRps < 1) throw new Error('totalRps must be a positive safe integer');
    if (!Number.isSafeInteger(physicalConnections) || physicalConnections < 1) throw new Error('physicalConnections must be a positive safe integer');
    const nodes = 4;
    const processesPerNode = 2;
    if (totalRps % (nodes * processesPerNode) !== 0 || physicalConnections % (nodes * processesPerNode) !== 0) {
        throw new Error('RPS and physical connections must divide exactly across 4 nodes and 2 processes per node');
    }
    return {
        totalRps,
        totalPhysicalConnections: physicalConnections,
        perNodeRps: totalRps / nodes,
        perNodeConnections: physicalConnections / nodes,
        perProcessRps: totalRps / nodes / processesPerNode,
        perProcessConnections: physicalConnections / nodes / processesPerNode,
        ohaParallel: 1,
    };
}

export function deterministicShuffle(values, seed) {
    const result = [...values];
    let state = seed >>> 0;
    for (let index = result.length - 1; index > 0; index--) {
        state ^= state << 13;
        state ^= state >>> 17;
        state ^= state << 5;
        const selected = (state >>> 0) % (index + 1);
        [result[index], result[selected]] = [result[selected], result[index]];
    }
    return result;
}

if (import.meta.url === `file://${process.argv[1]}`) {
    process.stdout.write(`${JSON.stringify(buildConnectionPathCrossoverPlan(Number(process.argv[2] ?? 20_260_715)), null, 2)}\n`);
}
