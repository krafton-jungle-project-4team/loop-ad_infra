{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LoopAd curated experiment evidence",
  "type": "object",
  "required": ["schemaVersion", "runId", "phase", "category", "executedAt", "purpose", "hypothesis", "topology", "majorSettings", "sourceRevision", "status", "rawStatus", "validity", "keyMetrics", "correctnessStatus", "costStatus", "cleanupStatus", "conclusion", "limitations", "relatedIncidents", "provenance", "sourceEvidence"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "runId": { "type": "string" },
    "phase": { "type": "string", "enum": ["phase0", "phase1", "phase2", "phase3", "phase4", "phase5", "phase6", "phase7", "phase8"] },
    "category": { "type": "string", "enum": ["experiment", "smoke", "qualification", "correctness", "diagnostic", "validation", "deployment_readiness", "cleanup", "other"] },
    "executedAt": { "type": "string" },
    "purpose": { "type": "string" },
    "hypothesis": { "type": "string" },
    "topology": { "type": "string" },
    "majorSettings": { "type": "array", "items": { "type": "object" } },
    "sourceRevision": { "type": "string" },
    "status": { "type": "string", "enum": ["passed", "failed", "aborted", "blocked", "inconclusive", "unknown"] },
    "rawStatus": { "type": "string" },
    "validity": { "type": "string", "enum": ["valid", "unknown", "invalidated", "inconclusive"] },
    "keyMetrics": { "type": "array", "items": { "type": "object" } },
    "correctnessStatus": { "type": "string" },
    "costStatus": { "type": "string" },
    "cleanupStatus": { "type": "string" },
    "conclusion": { "type": "string" },
    "limitations": { "type": "array", "items": { "type": "string" } },
    "relatedIncidents": { "type": "array", "items": { "type": "string" } },
    "provenance": { "type": "object", "required": ["snapshotId", "workspaceArchiveSha256", "sourcePaths"], "properties": { "snapshotId": { "type": "string" }, "workspaceArchiveSha256": { "type": "string" }, "sourcePaths": { "type": "array", "minItems": 1, "items": { "type": "string" } } },
    "sourceEvidence": { "type": "array", "items": { "type": "object" } }
  }
}
