{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LoopAd curated performance incident",
  "type": "object",
  "required": ["schemaVersion", "incidentId", "symptom", "rootCause", "fix", "regressionResult", "affectedRunIds", "period", "invalidationScope", "provenance"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "incidentId": { "type": "string" },
    "symptom": { "type": "string" },
    "rootCause": { "type": "string" },
    "fix": { "type": "string" },
    "regressionResult": { "type": "string" },
    "affectedRunIds": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "period": { "type": "object" },
    "invalidationScope": { "type": "string" },
    "provenance": { "type": "object" }
  }
}
