#!/usr/bin/env node

import { writeFileSync } from 'node:fs';

export function renderHAProxyConfig({
    backends,
    discoveryName,
    algorithm = 'leastconn',
    backendProtocol = 'h2',
    certificatePath = '/tmp/haproxy-secrets/haproxy.pem',
    threads = 4,
    maxConnections = 65_536,
    serverTemplateSlots = 8,
} = {}) {
    if ((backends === undefined) === (discoveryName === undefined)) throw new Error('provide exactly one of backends or discoveryName');
    if (backends !== undefined && (!Array.isArray(backends) || backends.length !== 4)) throw new Error('exactly four collector backends are required');
    if (discoveryName !== undefined && !/^_[a-z][a-z0-9-]*\._tcp\.[a-z][a-z0-9.-]+$/.test(discoveryName)) throw new Error('discoveryName must be an internal DNS SRV name');
    if (!['leastconn', 'roundrobin'].includes(algorithm)) throw new Error('algorithm must be leastconn or roundrobin');
    if (!['h2', 'h1'].includes(backendProtocol)) throw new Error('backendProtocol must be h2 or h1');
    if (!/^\/[A-Za-z0-9._/-]+\.pem$/.test(certificatePath)) throw new Error('certificatePath must be an absolute PEM path');
    if (!Number.isInteger(threads) || threads < 1 || threads > 64) throw new Error('threads must be an integer from 1 through 64');
    if (!Number.isInteger(maxConnections) || maxConnections < 12_000 || maxConnections > 1_000_000) throw new Error('maxConnections must cover the 12000-connection contract');
    if (!Number.isInteger(serverTemplateSlots) || serverTemplateSlots < 4 || serverTemplateSlots > 8) throw new Error('serverTemplateSlots must be an integer from 4 through 8');
    const servers = (backends ?? []).map((backend, index) => {
        if (!backend || typeof backend !== 'object' || !(isIpv4(backend.address) || backend.address === 'host.docker.internal') || !Number.isInteger(backend.port) || backend.port < 1 || backend.port > 65_535) {
            throw new Error(`invalid collector backend at index ${index}`);
        }
        const protocol = backendProtocol === 'h2' ? ' proto h2' : '';
        return `  server collector-${String(index + 1).padStart(2, '0')} ${backend.address}:${backend.port}${protocol} check inter 2s fall 2 rise 2`;
    });
    if (discoveryName) {
        servers.push(`  server-template collector 1-${serverTemplateSlots} ${discoveryName}${backendProtocol === 'h2' ? ' proto h2' : ''} check resolvers awsdns init-addr last,libc,none resolve-opts allow-dup-ip`);
    }
    return `${[
        'global',
        '  log stdout format raw local0',
        `  maxconn ${maxConnections}`,
        `  nbthread ${threads}`,
        '  stats socket /tmp/haproxy-admin.sock mode 660 level admin expose-fd listeners',
        '  ssl-default-bind-options ssl-min-ver TLSv1.2',
        '',
        'defaults',
        '  mode http',
        '  log global',
        '  option httplog',
        '  option dontlognull',
        '  timeout connect 3s',
        '  timeout client 15s',
        '  timeout server 15s',
        '  timeout http-request 10s',
        '  timeout client-fin 5s',
        '  timeout server-fin 5s',
        '  retries 0',
        '',
        'resolvers awsdns',
        '  nameserver vpc 169.254.169.253:53',
        '  accepted_payload_size 8192',
        '  hold valid 1s',
        '  resolve_retries 3',
        '  timeout resolve 1s',
        '  timeout retry 1s',
        '',
        'frontend events_h2',
        `  bind :8443 ssl crt ${certificatePath} alpn h2`,
        '  acl negotiated_h2 ssl_fc_alpn -i h2',
        '  http-request deny status 421 unless negotiated_h2',
        '  acl proxy_control path -i /__proxy_control',
        '  http-request return status 202 content-type text/plain string "proxy control accepted" if proxy_control',
        '  default_backend collectors',
        '',
        'frontend stats',
        '  bind :8404',
        '  http-request use-service prometheus-exporter if { path /metrics }',
        '  stats enable',
        '  stats uri /stats',
        '',
        'backend collectors',
        `  balance ${algorithm}`,
        '  option httpchk GET /health',
        '  http-check expect status 200',
        `  http-reuse ${backendProtocol === 'h2' ? 'always' : 'safe'}`,
        ...servers,
        '',
    ].join('\n')}\n`;
}

function isIpv4(value) {
    if (typeof value !== 'string') return false;
    const octets = value.split('.');
    return octets.length === 4 && octets.every((octet) => /^\d{1,3}$/.test(octet) && Number(octet) <= 255 && String(Number(octet)) === octet);
}

if (import.meta.url === `file://${process.argv[1]}`) {
    const backendsOption = optionValue('--backends');
    const discoveryName = optionValue('--discovery-name');
    const backends = backendsOption?.split(',').map((address) => ({ address, port: Number(optionValue('--backend-port') ?? 8080) }));
    const rendered = renderHAProxyConfig({
        backends,
        discoveryName,
        algorithm: optionValue('--algorithm') ?? 'leastconn',
        backendProtocol: optionValue('--backend-protocol') ?? 'h2',
        certificatePath: optionValue('--certificate-path') ?? '/tmp/haproxy-secrets/haproxy.pem',
        threads: Number(optionValue('--threads') ?? 4),
        maxConnections: Number(optionValue('--maxconn') ?? 65_536),
        serverTemplateSlots: Number(optionValue('--server-template-slots') ?? 8),
    });
    const output = optionValue('--output');
    if (output) writeFileSync(output, rendered, 'utf8');
    else process.stdout.write(rendered);
}

function optionValue(name) { const index = process.argv.indexOf(name); return index < 0 ? undefined : process.argv[index + 1]; }
function requiredOption(name) { const value = optionValue(name); if (!value) throw new Error(`${name} is required`); return value; }
