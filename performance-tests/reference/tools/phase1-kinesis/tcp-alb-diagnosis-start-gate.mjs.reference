#!/usr/bin/env node

import { readFileSync, writeFileSync } from 'node:fs';

const minimumWorkSeconds = { deploy: 1_200, session: 1_800, attempt: 600, stage: 300, cleanup: 0 };
const sessionId = requiredOption('--session-id');
const sessionPath = requiredOption('--session');
const action = requiredOption('--action');
const output = optionValue('--output');
const now = new Date(optionValue('--now') ?? Date.now());
const estimatedWorkSeconds = integerOption('--estimated-work-seconds', minimumWorkSeconds[action]);
if (!/^phase1-kinesis-(?:tcp-alb-path-diagnosis|protocol-crossover)-[0-9]{8}T[0-9]{6}Z$/.test(sessionId)) throw new Error('invalid session ID');
if (!Object.hasOwn(minimumWorkSeconds, action)) throw new Error('invalid action');
if (!Number.isFinite(now.getTime())) throw new Error('invalid now');

const session = JSON.parse(readFileSync(sessionPath, 'utf8'));
const legacyBudgetDefaults = { hardCapUsd: 30, newWorkStopUsd: 24, cleanupReserveUsd: 5 };
const hardCapUsd = session.hardLimits.incrementalHardCapUsd ?? legacyBudgetDefaults.hardCapUsd;
const newWorkStopUsd = session.hardLimits.newWorkStopUsd ?? legacyBudgetDefaults.newWorkStopUsd;
const cleanupReserveUsd = session.hardLimits.cleanupReserveUsd ?? legacyBudgetDefaults.cleanupReserveUsd;
const deadlineField = ['deploy', 'session'].includes(action) ? 'newDeployDeadlineUtc'
    : ['attempt', 'stage'].includes(action) ? 'newStageDeadlineUtc' : 'newWorkDeadlineUtc';
const startDeadline = new Date(session.hardLimits[deadlineField] ?? session.hardLimits.newWorkDeadlineUtc);
const hardDeadline = new Date(session.hardLimits.hardDeadlineUtc);
const modeledAccruedUsd = action === 'cleanup' ? null : JSON.parse(readFileSync(requiredOption('--accrued-cost'), 'utf8')).projectedCumulativeUpperBoundUsd;
const projectedTotalUsd = action === 'cleanup' ? null : JSON.parse(readFileSync(requiredOption('--projected-cost'), 'utf8')).projectedCumulativeUpperBoundUsd;
const checks = {
    sessionIdentityMatches: session.sessionId === sessionId && session.region === 'ap-northeast-2',
    deadlineOrderValid: startDeadline < hardDeadline,
    beforeHardDeadline: action === 'cleanup' || now < hardDeadline,
    startWindowOpen: action === 'cleanup' || now < startDeadline,
    conservativeEstimateProvided: action === 'cleanup' || estimatedWorkSeconds >= minimumWorkSeconds[action],
    projectedFinishBeforeHardDeadline: action === 'cleanup' || new Date(now.getTime() + estimatedWorkSeconds * 1_000) < hardDeadline,
	accruedBelowNewSessionStop: action === 'cleanup' || Number.isFinite(modeledAccruedUsd) && modeledAccruedUsd < newWorkStopUsd,
	projectedBelowHardLimit: action === 'cleanup' || Number.isFinite(projectedTotalUsd) && projectedTotalUsd < hardCapUsd,
	cleanupReserveProtected: action === 'cleanup' || Number.isFinite(projectedTotalUsd) && projectedTotalUsd + cleanupReserveUsd < hardCapUsd,
};
const result = {
    checkedAt: now.toISOString(), sessionId, action, estimatedWorkSeconds,
    deadlines: { selectedField: deadlineField, newWork: startDeadline.toISOString(), hard: hardDeadline.toISOString() },
	cost: { modeledAccruedUsd, projectedTotalUsd, hardCapUsd, newWorkStopUsd, cleanupReserveUsd },
    checks, passed: Object.values(checks).every(Boolean),
};
const serialized = `${JSON.stringify(result, null, 2)}\n`;
if (output) writeFileSync(output, serialized);
process.stdout.write(serialized);
if (!result.passed) process.exitCode = 2;

function requiredOption(name) { const value = optionValue(name); if (!value) throw new Error(`${name} is required`); return value; }
function optionValue(name) { const index = process.argv.indexOf(name); return index < 0 ? undefined : process.argv[index + 1]; }
function integerOption(name, fallback) { const raw = optionValue(name); const value = raw === undefined ? fallback : Number(raw); if (!Number.isInteger(value) || value < 0) throw new Error(`${name} must be non-negative`); return value; }
