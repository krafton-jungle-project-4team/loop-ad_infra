{
    "name": "loop-ad_aws_cdk",
    "version": "0.1.0",
    "private": true,
    "description": "Draft-only AWS CDK v2 infrastructure for loop-ad.",
    "license": "UNLICENSED",
    "scripts": {
        "build": "tsc --noEmit",
        "watch": "tsc -w",
        "test": "jest --runInBand",
        "synth:dev-certificate": "cdk -c environment=dev-certificate synth LoopAdDevCertificateStack",
        "synth:dev-repositories": "cdk -c environment=dev-repositories synth LoopAdDevRepositoryStack",
        "synth:dev-network": "cdk -c environment=dev-network synth LoopAdDevNetworkStack",
        "synth:dev-data": "cdk -c environment=dev-data synth LoopAdDevDataStack",
        "synth:dev-runtime": "cdk -c environment=dev-runtime synth LoopAdDevRuntimeStack",
        "synth:dev": "cdk -c environment=dev synth LoopAdDevDataStack LoopAdDevRuntimeStack",
        "deploy:dev-certificate": "cdk -c environment=dev-certificate deploy LoopAdDevCertificateStack",
        "deploy:dev-repositories": "cdk -c environment=dev-repositories deploy LoopAdDevRepositoryStack",
        "deploy:dev-network": "cdk -c environment=dev-network deploy LoopAdDevNetworkStack",
        "deploy:dev-data": "cdk -c environment=dev-data deploy LoopAdDevDataStack",
        "deploy:dev-runtime": "cdk -c environment=dev-runtime deploy LoopAdDevRuntimeStack",
        "deploy:dev": "cdk -c environment=dev deploy LoopAdDevNetworkStack LoopAdDevDataStack LoopAdDevRuntimeStack",
        "deploy": "node scripts/refuse-deploy.mjs",
        "destroy": "node scripts/refuse-deploy.mjs",
        "cdk": "cdk"
    },
    "devDependencies": {
        "@types/jest": "^29.5.14",
        "@types/node": "^20.0.0",
        "jest": "^29.7.0",
        "ts-jest": "^29.2.5",
        "aws-cdk": "2.1128.1",
        "ts-node": "^10.9.2",
        "typescript": "~5.9.3"
    },
    "dependencies": {
        "aws-cdk-lib": "^2.260.0",
        "constructs": "^10.5.0",
        "dotenv": "^17.4.2"
    }
}
