});

test('stage runner validates deployed topology, global stagger, proxy evidence, and stage gates', () => {
    const runner = readFileSync(new URL('./run-latency-root-cause-stage.mjs', import.meta.url), 'utf8');
    for (const topology of ['T0', 'T1', 'T2', 'T3']) assert.match(runner, new RegExp(topology));
    assert.match(runner, /validateConnectionPathIdentity/);
    assert.match(runner, /connection-path-deadline-gate\.mjs/);
    assert.match(runner, /processStartMode === 'staggered' \? `\$\{index \* 10\}`/);
    assert.match(runner, /collect-haproxy-telemetry\.mjs/);
    assert.match(runner, /physicalConnectionsAtLeast99Percent/);
    assert.match(runner, /protocolCorrect/);
});

test('runtime state redacts secret-bearing container environment values', () => {
    const collector = readFileSync(new URL('./collect-runtime-state.mjs', import.meta.url), 'utf8');
    assert.match(collector, /SECRET\|TOKEN\|PASSWORD\|PRIVATE_KEY/);
    assert.match(collector, /capture\(/);
    assert.match(collector, /\[REDACTED\]/);
});

test('HAProxy telemetry records raw proxy and host state and exports only run-owned artifacts', () => {
    const telemetry = readFileSync(new URL('./collect-haproxy-telemetry.mjs', import.meta.url), 'utf8');
    for (const evidence of ['/metrics', '/stats;csv', 'docker stats', 'ss -tin', '/proc/net/softnet_stat', 'nstat -az']) {
        assert.match(telemetry, new RegExp(evidence.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')));
    }
    assert.match(telemetry, /proxy-evidence/);
    assert.match(telemetry, /sha256sum/);
	assert.match(telemetry, /timeout --signal=TERM --kill-after=5s/);
    assert.match(telemetry, /docker_stats_pid=\$!/);
    assert.match(telemetry, /sample % 30/);
	assert.match(telemetry, /sample_epoch/);
	assert.match(telemetry, /sample_epoch=\$\(\(\$\{startEpoch\} \+ sample - 1\)\)/);
	assert.doesNotMatch(telemetry, /sample_epoch=\$\(\('\$\{startEpoch\}'/);
	assert.match(telemetry, /sleep "\$sleep_seconds"/);
	assert.match(telemetry, /samplesComplete/);
    assert.match(telemetry, /durationSeconds \+ 300/);
    assert.doesNotMatch(telemetry, /sleep 1/);
    assert.match(telemetry, /runId !== runId \|\| item\.sessionId !== sessionId/);
});
