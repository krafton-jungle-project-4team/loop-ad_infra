export function resourcesOf(template: { toJSON(): { Resources?: Record<string, unknown> } }): Record<string, { Type: string; Properties?: Record<string, unknown>; CreationPolicy?: Record<string, unknown>; DeletionPolicy?: string; DependsOn?: string[]; UpdateReplacePolicy?: string; UpdatePolicy?: Record<string, unknown> }> {
    return (template.toJSON().Resources ?? {}) as Record<string, { Type: string; Properties?: Record<string, unknown>; CreationPolicy?: Record<string, unknown>; DeletionPolicy?: string; DependsOn?: string[]; UpdateReplacePolicy?: string; UpdatePolicy?: Record<string, unknown> }>;
}

export function logicalIdBySecurityGroupDescription(resources: ReturnType<typeof resourcesOf>, description: string): string {
    const entry = Object.entries(resources).find(([, resource]) => (
        resource.Type === 'AWS::EC2::SecurityGroup' && resource.Properties?.GroupDescription === description
    ));
    if (!entry) {
        throw new Error(`Unable to find security group: ${description}`);
    }

    return entry[0];
}
