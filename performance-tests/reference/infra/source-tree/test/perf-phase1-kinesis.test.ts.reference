    it('creates exact-size On-Demand collector and load-generator ASGs without autoscaling', () => {
        const template = Template.fromStack(synthPerfPhase1Kinesis());
        const templateText = JSON.stringify(template.toJSON());
        const parameters = Object.values(template.toJSON().Parameters ?? {});

        template.resourceCountIs('AWS::AutoScaling::AutoScalingGroup', 2);
        template.hasResourceProperties('AWS::AutoScaling::AutoScalingGroup', {
            AutoScalingGroupName: 'perf-phase1-loop-ad-collector',
            InstanceMaintenancePolicy: {
                MinHealthyPercentage: 0,
                MaxHealthyPercentage: 100,
            },
            MinSize: '1',
            MaxSize: '1',
        });
        template.hasResourceProperties('AWS::AutoScaling::AutoScalingGroup', {
            AutoScalingGroupName: 'perf-phase1-loop-ad-load-generator',
            MinSize: '1',
            MaxSize: '1',
        });
        expect(templateText).not.toContain('"DesiredCapacity"');
        template.resourceCountIs('AWS::AutoScaling::ScalingPolicy', 0);
        template.resourceCountIs('AWS::AutoScaling::ScheduledAction', 0);
        template.resourceCountIs('AWS::AutoScaling::WarmPool', 0);
        expect(templateText).toContain('c6i.xlarge');
        expect(templateText).toContain('c6in.large');
        expect(templateText).toContain('"Monitoring":{"Enabled":true}');
        expect(templateText).not.toContain('"MarketType":"spot"');
        expect(parameters).toContainEqual(expect.objectContaining({
            Default: '/aws/service/ecs/optimized-ami/amazon-linux-2023/recommended/image_id',
        }));
        expect(templateText).not.toContain('/aws/service/ecs/optimized-ami/amazon-linux-2/');
        template.resourcePropertiesCountIs('AWS::EC2::LaunchTemplate', {
            LaunchTemplateData: Match.objectLike({
                MetadataOptions: { HttpTokens: 'required' },
            }),
        }, 2);
        const resources = Object.values(resourcesOf(template));
        const autoScalingGroups = resources.filter((resource) => resource.Type === 'AWS::AutoScaling::AutoScalingGroup');
        for (const autoScalingGroup of autoScalingGroups) {
            expect(autoScalingGroup.UpdatePolicy).toMatchObject({
                AutoScalingRollingUpdate: {
                    MinInstancesInService: 0,
                    SuspendProcesses: expect.arrayContaining(['AZRebalance', 'InstanceRefresh']),
                },
            });
        }

        const collectorAutoScalingGroup = autoScalingGroups.find((resource) => (
            resource.Properties?.AutoScalingGroupName === 'perf-phase1-loop-ad-collector'
        ));
        expect(collectorAutoScalingGroup?.CreationPolicy).toEqual({
            ResourceSignal: {
                Count: 1,
                Timeout: 'PT10M',
            },
        });
        const loadGeneratorAutoScalingGroup = autoScalingGroups.find((resource) => (
            resource.Properties?.AutoScalingGroupName === 'perf-phase1-loop-ad-load-generator'
        ));
        expect(loadGeneratorAutoScalingGroup?.CreationPolicy).toBeUndefined();
    });

    it('signals collector ASG readiness from a unit ordered after the ECS agent', () => {
        const template = Template.fromStack(synthPerfPhase1Kinesis({ phase1CollectorCount: 2 }));
        const resources = resourcesOf(template);
        const collectorAsgEntry = Object.entries(resources).find(([, resource]) => (
            resource.Type === 'AWS::AutoScaling::AutoScalingGroup' &&
            resource.Properties?.AutoScalingGroupName === 'perf-phase1-loop-ad-collector'
        ));
        const collectorLaunchTemplate = Object.values(resources).find((resource) => (
            resource.Type === 'AWS::EC2::LaunchTemplate' &&
            (resource.Properties?.LaunchTemplateData as Record<string, unknown>)?.InstanceType === 'c6i.xlarge'
        ));
        const collectorService = Object.values(resources).find((resource) => (
            resource.Type === 'AWS::ECS::Service'
        ));
        const userData = JSON.stringify((collectorLaunchTemplate?.Properties?.LaunchTemplateData as Record<string, unknown>)
            ?.UserData);

        expect(collectorAsgEntry?.[1].CreationPolicy).toEqual({
            ResourceSignal: { Count: 2, Timeout: 'PT10M' },
        });
        expect(userData).toContain('/etc/systemd/system/collector-cfn-signal.service');
        expect(userData).toContain('Wants=ecs.service');
        expect(userData).toContain('After=ecs.service');
        expect(userData).toContain('systemctl start --no-block collector-cfn-signal.service');
        expect(userData).not.toContain('systemctl enable --now collector-cfn-signal.service');
        expect(userData).toContain('http://127.0.0.1:51678/v1/metadata');
        expect(userData).toContain('ContainerInstanceArn');
        expect(userData).toContain('X-aws-ec2-metadata-token-ttl-seconds: 60');
        expect(userData).toContain('aws cloudformation signal-resource');
        expect(userData).toContain('--status FAILURE');
        expect(userData).toContain('--status SUCCESS');
        expect(userData).toContain(`--logical-resource-id ${collectorAsgEntry?.[0]}`);
        expect(collectorService?.DependsOn).toContain(collectorAsgEntry?.[0]);
        expect(collectorService?.Properties).toEqual(expect.objectContaining({ LaunchType: 'EC2' }));
        expect(Object.values(resources).some((resource) => (
            resource.Type === 'AWS::ECS::CapacityProvider' ||
            resource.Type === 'AWS::ECS::ClusterCapacityProviderAssociations'
        ))).toBe(false);

        const collectorInstanceRoleEntry = Object.entries(resources).find(([, resource]) => (
            resource.Type === 'AWS::IAM::Role' &&
            resource.Properties?.RoleName === 'loop-ad-perf-phase1-collector-instance'
        ));
        const collectorInstancePolicy = Object.values(resources).find((resource) => (
            resource.Type === 'AWS::IAM::Policy' &&
            (resource.Properties?.Roles as Array<{ Ref?: string }> | undefined)
                ?.some((role) => role.Ref === collectorInstanceRoleEntry?.[0])
        ));
        expect(collectorInstancePolicy?.Properties?.PolicyDocument).toEqual(expect.objectContaining({
            Statement: expect.arrayContaining([{
                Action: 'cloudformation:SignalResource',
                Effect: 'Allow',
                Resource: { Ref: 'AWS::StackId' },
            }]),
        }));
    });

