    it('fails closed when immutable run identity context is malformed', () => {
        expect(() => synthPerfPhase1Kinesis({ phase1CollectorSha: 'deadbeef' })).toThrow(
            'phase1CollectorSha must be a full lowercase 40-character Git SHA',
        );
        expect(() => synthPerfPhase1Kinesis({ phase1CollectorImageDigest: 'sha256:deadbeef' })).toThrow(
            'phase1CollectorImageDigest must be a lowercase sha256 image digest',
        );
        expect(() => synthPerfPhase1Kinesis({ phase1RunId: 'manual' })).toThrow(
            'phase1RunId must match run_YYYYMMDD_HHMMSS_<label>',
        );
        expect(() => synthPerfPhase1Kinesis({ phase1SessionId: 'manual' })).toThrow(
            'phase1SessionId must match phase1-compare-YYYYMMDD-HHMMSSz',
        );
        expect(() => synthPerfPhase1Kinesis({ phase1Candidate: 'unknown' })).toThrow(
            'phase1Candidate must be one of go-sync, go-batch, or java-kpl',
        );
    });

    it('keeps capacity mode separate and fixes four hosts, tasks, tags, and image identity', () => {
        const runStack = synthPerfPhase1KinesisCapacity();
        const template = Template.fromStack(runStack);
        const templateText = JSON.stringify(template.toJSON());

        expect(runStack.stackName).toBe('LoopAdPerfPhase1KinesisCapacityStack');
        template.hasResourceProperties('AWS::AutoScaling::AutoScalingGroup', {
            AutoScalingGroupName: 'perf-phase1-loop-ad-collector',
            MinSize: '4', MaxSize: '4',
        });
        template.hasResourceProperties('AWS::ECS::Service', {
            DesiredCount: 4,
            PlacementConstraints: [{ Type: 'distinctInstance' }],
            EnableECSManagedTags: true,
            PropagateTags: 'SERVICE',
        });
        template.hasOutput('Phase1ExperimentMode', { Value: 'capacity' });
        template.hasOutput('Phase1CollectorCount', { Value: '4' });
        template.hasOutput('Phase1RequiredOnDemandVcpus', { Value: '18' });
        template.hasOutput('Phase1CollectorImageTag', {
            Value: `phase1-capacity-20260712T081500Z-go-sync-${testPhase1Context.phase1CollectorSha}`,
        });
        for (const [key, value] of Object.entries({
            SessionId: 'phase1-capacity-20260712T081500Z',
            RunId: 'run_20260712_081500_capacity_go_sync',
            Phase: 'phase1-capacity', ManagedBy: 'codex', Owner: 'loop-ad',
        })) {
            expect(templateText).toContain(`\"Key\":\"${key}\",\"Value\":\"${value}\"`);
        }
        expect(() => synthPerfPhase1KinesisCapacity({ phase1CollectorCount: 3 })).toThrow(
            'phase1CollectorCount must be exactly 4 in capacity or scout mode',
        );
        expect(() => synthPerfPhase1KinesisCapacity({ phase1SessionId: testPhase1Context.phase1SessionId })).toThrow(
            'phase1SessionId must match phase1-capacity-YYYYMMDDTHHMMSSZ in capacity mode',
        );
    });

    it('uses a new capacity stream stack identity and ownership tags', () => {
        const streamStack = synthPerfPhase1KinesisCapacityStream();
        const template = Template.fromStack(streamStack);
        const templateText = JSON.stringify(template.toJSON());

        expect(streamStack.stackName).toBe('LoopAdPerfPhase1KinesisCapacityStreamStack');
        for (const [key, value] of Object.entries({
            SessionId: 'phase1-capacity-20260712T081500Z',
            RunId: 'phase1-capacity-20260712T081500Z',
            Phase: 'phase1-capacity', ManagedBy: 'codex', Owner: 'loop-ad',
        })) {
            expect(templateText).toContain(`\"Key\":\"${key}\",\"Value\":\"${value}\"`);
        }
    });

    it('keeps scout resources and ownership distinct from final capacity', () => {
        const runStack = synthPerfPhase1KinesisScout();
        const streamStack = synthPerfPhase1KinesisScoutStream();
        const template = Template.fromStack(runStack);
        const text = JSON.stringify(template.toJSON());

        expect(runStack.stackName).toBe('LoopAdPerfPhase1KinesisCapacityScoutStack');
        expect(streamStack.stackName).toBe('LoopAdPerfPhase1KinesisCapacityScoutStreamStack');
        template.hasResourceProperties('AWS::ECS::Service', { DesiredCount: 4 });
        template.hasOutput('Phase1ExperimentMode', { Value: 'scout' });
        expect(text).toContain('phase1-capacity-scout-20260712T120000Z-go-sync');
        expect(text).toContain('\"Key\":\"Phase\",\"Value\":\"phase1-capacity-scout\"');
        expect(() => synthPerfPhase1KinesisScout({ phase1SessionId: 'phase1-capacity-20260712T120000Z' })).toThrow(
            'phase1SessionId must match phase1-capacity-scout-YYYYMMDDTHHMMSSZ in scout mode',
        );
    });

    it('keeps oha12k stacks separate and fixes an exact 1, 2, or 4 generator topology', () => {
        const runStack = synthPerfPhase1KinesisOha12k();
        const streamStack = synthPerfPhase1KinesisOha12kStream();
        const template = Template.fromStack(runStack);
        const text = JSON.stringify(template.toJSON());

        expect(runStack.stackName).toBe('LoopAdPerfPhase1KinesisCapacityOha12kStack');
        expect(streamStack.stackName).toBe('LoopAdPerfPhase1KinesisCapacityOha12kStreamStack');
        template.hasResourceProperties('AWS::AutoScaling::AutoScalingGroup', {
            AutoScalingGroupName: 'perf-phase1-loop-ad-load-generator',
            MinSize: '2', MaxSize: '2',
        });
        template.hasOutput('Phase1ExperimentMode', { Value: 'capacity-oha12k' });
        template.hasOutput('Phase1LoadGeneratorCount', { Value: '2' });
        template.hasOutput('Phase1RequiredOnDemandVcpus', { Value: '20' });
        expect(text).toContain('"Key":"Phase","Value":"phase1-capacity-oha12k"');
        expect(() => synthPerfPhase1KinesisOha12k({ phase1LoadGeneratorCount: 3 })).toThrow(
            'phase1LoadGeneratorCount must be 1, 2, or 4 in capacity-oha12k mode.',
        );
        expect(() => synthPerfPhase1KinesisCapacity({ phase1LoadGeneratorCount: 2 })).toThrow(
            'phase1LoadGeneratorCount must remain 1 outside capacity-oha12k mode.',
        );
    });

    it('isolates generator qualification behind a fixed-response ALB without collectors or Kinesis', () => {
        const stack = synthPerfPhase1GeneratorControl();
        const template = Template.fromStack(stack);
        const text = JSON.stringify(template.toJSON());

        expect(stack.stackName).toBe('LoopAdPerfPhase1KinesisGeneratorControlStack');
        template.resourceCountIs('AWS::ECS::Service', 0);
        template.resourceCountIs('AWS::ECS::TaskDefinition', 0);
        template.resourceCountIs('AWS::Kinesis::Stream', 0);
        template.resourceCountIs('AWS::AutoScaling::AutoScalingGroup', 1);
        template.hasResourceProperties('AWS::AutoScaling::AutoScalingGroup', {
            AutoScalingGroupName: 'perf-phase1-generator-control', MinSize: '1', MaxSize: '1',
        });
        template.hasResourceProperties('AWS::ElasticLoadBalancingV2::Listener', {
            DefaultActions: [Match.objectLike({
                Type: 'fixed-response',
                FixedResponseConfig: Match.objectLike({ StatusCode: '202' }),
            })],
        });
        expect(text).toContain('"Key":"Phase","Value":"phase1-generator-diagnosis"');
        expect(text).toContain('"Key":"TargetKind","Value":"fast-control"');
        expect(text).toContain('AmazonSSMManagedInstanceCore');
    });

    it('uses new diagnosis stack identities for actual Kinesis candidate probes', () => {
        const runStack = synthPerfPhase1GeneratorDiagnosis();
        const streamStack = synthPerfPhase1GeneratorDiagnosisStream();
        const template = Template.fromStack(runStack);
        expect(runStack.stackName).toBe('LoopAdPerfPhase1KinesisGeneratorDiagnosisStack');
        expect(streamStack.stackName).toBe('LoopAdPerfPhase1KinesisGeneratorDiagnosisStreamStack');
        template.hasOutput('Phase1ExperimentMode', { Value: 'generator-diagnosis' });
        expect(JSON.stringify(template.toJSON())).toContain('"Key":"Phase","Value":"phase1-generator-diagnosis"');
    });
});

function protocolPortMappings(template: Template): Record<string, unknown>[] {
	const taskDefinition = Object.values(resourcesOf(template)).find((resource) => resource.Type === 'AWS::ECS::TaskDefinition');
	const containers = taskDefinition?.Properties?.ContainerDefinitions as Array<{ PortMappings?: Record<string, unknown>[] }>;
	return containers?.[0]?.PortMappings?.filter((mapping) => mapping.ContainerPort === 8443) ?? [];
}

function nlbHealthIngressCount(template: Template): number {
	return Object.values(resourcesOf(template))
		.filter((resource) => resource.Type === 'AWS::EC2::SecurityGroup')
		.flatMap((resource) => (resource.Properties?.SecurityGroupIngress ?? []) as Record<string, unknown>[])
		.filter((ingress) => ingress.FromPort === 8080 && ingress.CidrIp !== undefined)
		.length;
}

function nlbDataIngressCount(template: Template, protocol: 'tcp' | 'udp'): number {
	return Object.values(resourcesOf(template))
		.filter((resource) => resource.Type === 'AWS::EC2::SecurityGroup')
		.flatMap((resource) => (resource.Properties?.SecurityGroupIngress ?? []) as Record<string, unknown>[])
		.filter((ingress) => ingress.FromPort === 8443 && ingress.IpProtocol === protocol && ingress.CidrIp !== undefined)
		.length;
}

function connectionPathCollectorTlsIngressCount(template: Template): number {
	return Object.values(resourcesOf(template))
		.filter((resource) => resource.Type === 'AWS::EC2::SecurityGroup')
		.flatMap((resource) => (resource.Properties?.SecurityGroupIngress ?? []) as Record<string, unknown>[])
		.filter((ingress) => ingress.FromPort === 8443 && ingress.IpProtocol === 'tcp' && ingress.CidrIp !== undefined &&
			ingress.Description === 'Client-IP-preserving NLB traffic may reach collector TLS HTTP/2.')
		.length;
}

function connectionPathGeneratorTlsEgressCount(template: Template): number {
	return Object.values(resourcesOf(template))
		.filter((resource) => resource.Type === 'AWS::EC2::SecurityGroup')
		.flatMap((resource) => (resource.Properties?.SecurityGroupEgress ?? []) as Record<string, unknown>[])
		.filter((egress) => egress.FromPort === 8443 && egress.IpProtocol === 'tcp' && egress.CidrIp !== undefined &&
			egress.Description === 'Load generator may run direct collector TLS readiness probes.')
		.length;
}
